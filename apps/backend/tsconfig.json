{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "CommonJS",
		"declaration": true,
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"allowSyntheticDefaultImports": true,
		"target": "ES2021",
		"sourceMap": true,
		"outDir": "./dist",
		"baseUrl": "./",
		"incremental": true,
		"skipLibCheck": true,
		"paths": {
			"@calorie-tracker/shared-types": [
				"../../libs/shared-types/src/index.ts"
			]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
