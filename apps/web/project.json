{
	"name": "web",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"sourceRoot": "apps/web",
	"targets": {
		"dev": {
			"executor": "nx:run-commands",
			"options": { "command": "next dev", "cwd": "apps/web" }
		},
		"build": {
			"executor": "nx:run-commands",
			"options": { "command": "next build", "cwd": "apps/web" },
			"outputs": ["{workspaceRoot}/apps/web/.next"]
		},
		"start": {
			"executor": "nx:run-commands",
			"options": { "command": "next start", "cwd": "apps/web" }
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": { "command": "next lint", "cwd": "apps/web" }
		}
	}
}
