{
	"name": "calorie-tracker-monorepo",
	"version": "0.0.0",
	"private": true,
	"workspaces": ["apps/mobile", "apps/backend", "apps/web", "libs/shared-types"],
	"scripts": {
		"mobile:start": "nx run mobile:start",
		"mobile:android": "nx run mobile:android",
		"mobile:ios": "nx run mobile:ios",
		"backend:serve": "nx run backend:serve",
		"backend:build": "nx run backend:build",
		"web:dev": "nx run web:dev",
		"web:build": "nx run web:build",
		"web:start": "nx run web:start",
		"dev": "concurrently \"nx run backend:serve\" \"nx run mobile:start\""
	},
	"devDependencies": {
		"@nx/expo": "^20.0.0",
		"@nx/nest": "^20.0.0",
		"@nx/js": "^20.0.0",
		"@nx/next": "^20.0.0",
		"nx": "^20.0.0",
		"typescript": "^5.3.3",
		"concurrently": "^9.0.0"
	}
}
